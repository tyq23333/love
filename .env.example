# Claude API（必填）
ANTHROPIC_API_KEY=sk-ant-xxx
# 模型（claude-sonnet-4-20250514 已下线，请用下面之一）
ANTHROPIC_MODEL=claude-sonnet-4-6
# Claude/fal 走代理时用 ANTHROPIC_PROXY（勿用 HTTPS_PROXY，否则微信也会误走代理）
# ANTHROPIC_PROXY=http://127.0.0.1:7890

# Telegram（不需要可关闭）
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# 钉钉（不需要可留空）
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=
DINGTALK_WEBHOOK_SECRET=
DINGTALK_WEBHOOK_PORT=3000

# 访问控制: 逗号分隔的用户ID白名单，留空=允许所有人（仅开发用）
ALLOWED_USER_IDS=

# Claude Code 允许使用的工具
ALLOWED_TOOLS=Read,Glob,Grep,Write

# Claude Code 工作目录
WORKING_DIR=

# Whisper 语音识别模型（Telegram 语音消息需要）
WHISPER_MODEL=base

# ── fal.ai 自拍（克劳德发自拍图）──
FAL_KEY=
# 自拍模型（Model ID）：
#   fal-ai/flux-2-max/edit     — 最强写实（推荐）
#   xai/grok-imagine-image/edit — 快、便宜
#   fal-ai/flux-pro/kontext/multi — 多参考图
FAL_MODEL=fal-ai/flux-2-max/edit
# 单张参考脸图 URL
SELFIE_REFERENCE_URL=
# 多张参考图（逗号分隔，最多 3 张；填了此项会覆盖 SELFIE_REFERENCE_URL）
# 顺序建议：正脸, 侧脸, 半身
# SELFIE_REFERENCE_URLS=https://v3b.fal.media/.../face.jpg,https://v3b.fal.media/.../side.jpg

# 微信 iLink ClawBot（设为 true 启用，首次启动需扫码登录）
WECHAT_ENABLED=true

# 云端持久化目录（Railway Volume 挂载点，如 /data；本地可留空）
# PERSIST_DIR=/data

# 对话记忆：近期原文条数（默认 40）；超出部分会压进长期摘要
# MEMORY_MAX_MESSAGES=40
# MEMORY_SUMMARY_ENABLED=true
# MEMORY_SUMMARY_MODEL=claude-haiku-4-5-20251001
