{
  "name": "im-claude",
  "version": "1.0.0",
  "description": "Claude Code IM Bridge - WeChat & Telegram",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "echo skip-tsc",
    "typecheck": "tsc --noEmit",
