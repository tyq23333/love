    "@fal-ai/client": "^1.10.1",
    "axios": "^1.7.0",
    "cron": "^3.1.7",
    "dotenv": "^16.4.0",
    "form-data": "^4.0.5",
    "grammy": "^1.31.0",
    "hono": "^4.6.0",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.35.3",
    "tsx": "^4.19.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
